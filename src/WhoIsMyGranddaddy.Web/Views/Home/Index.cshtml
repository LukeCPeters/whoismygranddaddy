@{
    ViewData["Title"] = "Home";
}
<section class="hero">
    <p class="eyebrow">Lineage explorer</p>
    <h1>Who is my granddaddy</h1>
    <p class="lead">Trace a family line from a single South African ID number — explore every descendant, or find the oldest ancestor in a person's lineage.</p>
</section>

<div class="cards">
    <a class="card" href="/Tree">
        <p class="eyebrow">View descendants</p>
        <h2>Family Tree Viewer</h2>
        <p>See all descendants of a person, expanding ten generations at a time.</p>
        <span class="card-link">Open →</span>
    </a>
    <a class="card" href="/Ancestor">
        <p class="eyebrow">Trace upward</p>
        <h2>Root Ascendant</h2>
        <p>Find the oldest reachable ancestor in a person's lineage.</p>
        <span class="card-link">Open →</span>
    </a>
</div>
